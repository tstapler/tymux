{
  "name": "@tymux/ts-client",
  "version": "1.0.0-alpha.7",
  "private": true,
  "type": "module",
  "description": "TypeScript client + examples proving tymuxd's gRPC API is usable cross-language (ADR-003).",
  "scripts": {
    "generate": "buf generate ../../proto",
    "build": "tsc -p tsconfig.json",
    "list-sessions": "tsx examples/list-sessions.ts",
    "attach": "tsx examples/attach.ts",
    "capture-pane": "tsx examples/capture-pane.ts",
    "test": "tsx --test test/*.test.ts"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.2.3",
    "@connectrpc/connect": "^2.0.2",
    "@connectrpc/connect-node": "^2.0.2"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.47.2",
    "@bufbuild/protoc-gen-es": "^2.2.3",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
